#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'

APP_DIR="/opt/masterdns-3xui"
BACKUP_DIR="$APP_DIR/backups"
MASTERDNS_DIR="/opt/masterdnsvpn"
XUI_DB="/etc/x-ui/x-ui.db"
XUI_ENV_FILES=("/etc/default/x-ui" "/etc/sysconfig/x-ui" "/etc/conf.d/x-ui")
WARP_OUTBOUND_TAG="warp"
WARP_PROXY_PORT="40000"

red=$'\033[0;31m'
green=$'\033[0;32m'
yellow=$'\033[0;33m'
blue=$'\033[0;34m'
plain=$'\033[0m'

info() { echo -e "${blue}[INFO]${plain} $*"; }
ok() { echo -e "${green}[OK]${plain} $*"; }
warn() { echo -e "${yellow}[WARN]${plain} $*"; }
err() { echo -e "${red}[ERROR]${plain} $*" >&2; }
die() { err "$*"; exit 1; }

need_root() { [[ "${EUID}" -eq 0 ]] || die "Run as root: sudo masterdns-3xui"; }
pause() { read -r -p "Press Enter to continue... " _ || true; }

confirm() {
  local prompt="${1:-Continue?}"
  local default="${2:-Y}"
  local ans
  read -r -p "${prompt} [${default}/n]: " ans
  ans="${ans:-$default}"
  [[ "$ans" == "y" || "$ans" == "Y" || "$ans" == "yes" || "$ans" == "YES" ]]
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "Missing command: $1. Re-run install.sh to install dependencies."
}

detect_pm() {
  if command -v apt-get >/dev/null 2>&1; then echo apt
  elif command -v dnf >/dev/null 2>&1; then echo dnf
  elif command -v yum >/dev/null 2>&1; then echo yum
  elif command -v pacman >/dev/null 2>&1; then echo pacman
  elif command -v zypper >/dev/null 2>&1; then echo zypper
  elif command -v apk >/dev/null 2>&1; then echo apk
  else die "No supported package manager found."
  fi
}

install_tools() {
  local pm
  pm="$(detect_pm)"
  case "$pm" in
    apt)
      apt-get update
      apt-get install -y curl wget ca-certificates jq sqlite3 iproute2 lsof unzip tar openssl
      ;;
    dnf) dnf -y install curl wget ca-certificates jq sqlite iproute lsof unzip tar openssl ;;
    yum) yum -y install curl wget ca-certificates jq sqlite iproute lsof unzip tar openssl ;;
    pacman) pacman -Sy --noconfirm curl wget ca-certificates jq sqlite iproute2 lsof unzip tar openssl ;;
    zypper)
      zypper refresh
      zypper -q install -y curl wget ca-certificates jq sqlite3-tools iproute2 lsof unzip tar openssl
      ;;
    apk)
      apk update
      apk add curl wget ca-certificates jq sqlite iproute2 lsof unzip tar openssl
      ;;
  esac
}

ensure_dirs() {
  mkdir -p "$APP_DIR" "$BACKUP_DIR"
}

timestamp() { date +%Y%m%d-%H%M%S; }

backup_file() {
  local file="$1"
  [[ -f "$file" ]] || return 0
  cp -a "$file" "$BACKUP_DIR/$(basename "$file").$(timestamp).bak"
}

check_sqlite_mode() {
  for f in "${XUI_ENV_FILES[@]}"; do
    if [[ -f "$f" ]] && grep -q '^XUI_DB_TYPE=postgres' "$f"; then
      die "Automatic WARP editing currently supports 3x-ui SQLite only. Use the original panel WARP menu for PostgreSQL installs."
    fi
  done
  [[ -f "$XUI_DB" ]] || die "3x-ui SQLite DB not found at $XUI_DB. Install 3x-ui first."
}

sqlite_get_setting() {
  local key="$1"
  sqlite3 "$XUI_DB" "SELECT value FROM settings WHERE key = '$key' ORDER BY id DESC LIMIT 1;"
}

sqlite_set_setting_file() {
  local key="$1"
  local value_file="$2"
  require_cmd sqlite3
  require_cmd jq
  local compact escaped
  compact="$(jq -c . "$value_file")"
  escaped="$(printf '%s' "$compact" | sed "s/'/''/g")"
  sqlite3 "$XUI_DB" "UPDATE settings SET value = '$escaped' WHERE key = '$key';"
  if [[ "$(sqlite3 "$XUI_DB" "SELECT changes();")" == "0" ]]; then
    sqlite3 "$XUI_DB" "INSERT INTO settings(key, value) VALUES('$key', '$escaped');"
  fi
}

default_xray_config() {
  cat <<'JSON'
{
  "api": {"services": ["HandlerService", "LoggerService", "StatsService"], "tag": "api"},
  "inbounds": [{"listen": "127.0.0.1", "port": 62789, "protocol": "tunnel", "settings": {"rewriteAddress": "127.0.0.1"}, "tag": "api"}],
  "log": {"access": "none", "dnsLog": false, "error": "", "loglevel": "warning", "maskAddress": ""},
  "metrics": {"listen": "127.0.0.1:11111", "tag": "metrics_out"},
  "outbounds": [
    {"protocol": "freedom", "settings": {"domainStrategy": "AsIs", "finalRules": [{"action": "allow", "ip": ["geoip:private"]}]}, "tag": "direct"},
    {"protocol": "blackhole", "settings": {}, "tag": "blocked"}
  ],
  "policy": {"levels": {"0": {"statsUserDownlink": true, "statsUserUplink": true}}, "system": {"statsInboundDownlink": true, "statsInboundUplink": true, "statsOutboundDownlink": false, "statsOutboundUplink": false}},
  "routing": {"domainStrategy": "AsIs", "rules": [
    {"inboundTag": ["api"], "outboundTag": "api", "type": "field"},
    {"ip": ["geoip:private"], "outboundTag": "blocked", "type": "field"},
    {"outboundTag": "blocked", "protocol": ["bittorrent"], "type": "field"}
  ]},
  "stats": {}
}
JSON
}

get_xray_config_file() {
  local out="$1"
  local raw
  raw="$(sqlite_get_setting xrayTemplateConfig || true)"
  if [[ -z "$raw" ]]; then
    default_xray_config > "$out"
  else
    printf '%s' "$raw" > "$out"
  fi
  jq empty "$out" >/dev/null
}

save_xray_config_file() {
  local file="$1"
  jq empty "$file" >/dev/null
  backup_file "$XUI_DB"
  sqlite_set_setting_file xrayTemplateConfig "$file"
}

set_warp_setting_file() {
  local file="$1"
  backup_file "$XUI_DB"
  sqlite_set_setting_file warp "$file"
}

restart_xui() {
  if command -v systemctl >/dev/null 2>&1 && systemctl list-unit-files 2>/dev/null | grep -q '^x-ui\.service'; then
    systemctl restart x-ui
  elif command -v rc-service >/dev/null 2>&1; then
    rc-service x-ui restart
  else
    warn "Could not restart x-ui automatically. Run: sudo x-ui restart"
  fi
}

restart_masterdns() {
  if command -v systemctl >/dev/null 2>&1 && systemctl list-unit-files 2>/dev/null | grep -q '^masterdnsvpn\.service'; then
    systemctl restart masterdnsvpn
  else
    warn "MasterDnsVPN service not found."
  fi
}

warp_cli() {
  warp-cli --accept-tos "$@" 2>/dev/null || warp-cli "$@"
}

install_cloudflare_warp() {
  if command -v warp-cli >/dev/null 2>&1; then
    ok "Cloudflare WARP is already installed."
    return 0
  fi

  local pm codename
  pm="$(detect_pm)"
  case "$pm" in
    apt)
      apt-get update
      apt-get install -y curl ca-certificates gpg lsb-release
      codename="$(lsb_release -cs 2>/dev/null || true)"
      if [[ -z "$codename" ]]; then
        . /etc/os-release
        codename="${VERSION_CODENAME:-}"
      fi
      [[ -n "$codename" ]] || die "Could not detect Debian/Ubuntu codename for Cloudflare WARP repository."
      mkdir -p /usr/share/keyrings
      curl -fsSL https://pkg.cloudflareclient.com/pubkey.gpg | gpg --yes --dearmor --output /usr/share/keyrings/cloudflare-warp-archive-keyring.gpg
      echo "deb [signed-by=/usr/share/keyrings/cloudflare-warp-archive-keyring.gpg] https://pkg.cloudflareclient.com/ $codename main" > /etc/apt/sources.list.d/cloudflare-client.list
      apt-get update
      apt-get install -y cloudflare-warp
      ;;
    dnf|yum)
      rpm --import https://pkg.cloudflareclient.com/pubkey.gpg || true
      curl -fsSL https://pkg.cloudflareclient.com/cloudflare-warp-ascii.repo -o /etc/yum.repos.d/cloudflare-warp.repo
      "$pm" -y install cloudflare-warp
      ;;
    *)
      die "Automatic Cloudflare WARP package install supports apt, dnf, and yum servers. Install cloudflare-warp manually, then run this menu again."
      ;;
  esac
}

start_warp_service() {
  if command -v systemctl >/dev/null 2>&1; then
    systemctl enable --now warp-svc >/dev/null 2>&1 && return 0
  fi
  if command -v service >/dev/null 2>&1; then
    service warp-svc start >/dev/null 2>&1 && return 0
  fi
  warn "Could not start warp-svc automatically. If WARP test fails, run: sudo systemctl start warp-svc"
}

set_warp_proxy_mode() {
  install_cloudflare_warp
  start_warp_service

  if ! warp_cli registration show >/dev/null 2>&1; then
    warp_cli registration new || warp_cli register || true
  fi

  warp_cli tunnel protocol set MASQUE >/dev/null 2>&1 || true
  warp_cli mode proxy >/dev/null 2>&1 || warp_cli set-mode proxy >/dev/null 2>&1 || die "Could not set WARP proxy mode."
  warp_cli connect >/dev/null 2>&1 || true

  local i
  for i in $(seq 1 20); do
    if command -v ss >/dev/null 2>&1 && ss -ltn 2>/dev/null | grep -q ":$WARP_PROXY_PORT "; then
      ok "Cloudflare WARP local proxy is listening on 127.0.0.1:$WARP_PROXY_PORT."
      return 0
    fi
    sleep 1
  done
  warn "Could not confirm WARP proxy port $WARP_PROXY_PORT. Continuing; use Test public IP to verify."
}

ensure_warp_socks_outbound() {
  check_sqlite_mode
  set_warp_proxy_mode
  local tmp next
  tmp="$(mktemp)"
  next="$(mktemp)"
  get_xray_config_file "$tmp"

  jq --arg tag "$WARP_OUTBOUND_TAG" --argjson port "$WARP_PROXY_PORT" '
    .outbounds = ((.outbounds // []) | map(select(.tag != $tag)) + [{
      tag: $tag,
      protocol: "socks",
      settings: {servers: [{address: "127.0.0.1", port: $port, users: []}]}
    }]) |
    .inbounds = ((.inbounds // []) | map(select(.tag != "masterdns-warp-socks"))) |
    .routing.rules = ((.routing.rules // []) | map(select(
      (.outboundTag != "api" or (.inboundTag // []) != ["api"])
      and ((.inboundTag // []) != ["masterdns-warp-socks"])
    ))) |
    .routing.rules = ([{type:"field", inboundTag:["api"], outboundTag:"api"}] + (.routing.rules // []))
  ' "$tmp" > "$next"
  save_xray_config_file "$next"
  rm -f "$tmp" "$next"
  ok "3x-ui Xray SOCKS outbound points to Cloudflare WARP proxy."
}

enable_xui_warp_all() {
  ensure_warp_socks_outbound
  local tmp next
  tmp="$(mktemp)"
  next="$(mktemp)"
  get_xray_config_file "$tmp"
  jq --arg tag "$WARP_OUTBOUND_TAG" '
    .routing.rules = ((.routing.rules // []) | map(select(. != {"type":"field","outboundTag":$tag}))) |
    .routing.rules = ((.routing.rules // []) + [{type:"field", outboundTag:$tag}])
  ' "$tmp" > "$next"
  save_xray_config_file "$next"
  restart_xui
  ok "3x-ui default outbound routing now uses Cloudflare WARP local SOCKS proxy."
}

disable_xui_warp_all() {
  check_sqlite_mode
  local tmp next
  tmp="$(mktemp)"
  next="$(mktemp)"
  get_xray_config_file "$tmp"
  jq --arg tag "$WARP_OUTBOUND_TAG" '.routing.rules = ((.routing.rules // []) | map(select(. != {"type":"field","outboundTag":$tag})))' "$tmp" > "$next"
  save_xray_config_file "$next"
  restart_xui
  rm -f "$tmp" "$next"
  ok "3x-ui catch-all WARP routing disabled. The local SOCKS outbound remains available in the panel."
}

remove_generated_warp_from_xray() {
  check_sqlite_mode
  local tmp next
  tmp="$(mktemp)"
  next="$(mktemp)"
  get_xray_config_file "$tmp"
  backup_file "$XUI_DB"
  jq --arg tag "$WARP_OUTBOUND_TAG" '
    .outbounds = ((.outbounds // []) | map(select(.tag != $tag))) |
    .inbounds = ((.inbounds // []) | map(select(.tag != "masterdns-warp-socks"))) |
    .routing.rules = ((.routing.rules // []) | map(select(
      .outboundTag != $tag
      and ((.inboundTag // []) != ["masterdns-warp-socks"])
    )))
  ' "$tmp" > "$next"
  save_xray_config_file "$next"
  rm -f "$tmp" "$next"
  ok "Generated WARP SOCKS outbound, catch-all route, and old MasterDnsVPN bridge removed from Xray config."
}

patch_masterdns_config() {
  local config="$MASTERDNS_DIR/server_config.toml"
  [[ -f "$config" ]] || die "MasterDnsVPN config not found: $config"
  backup_file "$config"
  set_or_append_toml "$config" "USE_EXTERNAL_SOCKS5" "true"
  set_or_append_toml "$config" "FORWARD_IP" '"127.0.0.1"'
  set_or_append_toml "$config" "FORWARD_PORT" "$WARP_PROXY_PORT"
  set_or_append_toml "$config" "SOCKS5_AUTH" "false"
}

set_or_append_toml() {
  local file="$1"
  local key="$2"
  local value="$3"
  if grep -qE "^${key}[[:space:]]*=" "$file"; then
    sed -i -E "s|^${key}[[:space:]]*=.*$|${key} = ${value}|" "$file"
  else
    printf '\n%s = %s\n' "$key" "$value" >> "$file"
  fi
}

unpatch_masterdns_config() {
  local config="$MASTERDNS_DIR/server_config.toml"
  [[ -f "$config" ]] || die "MasterDnsVPN config not found: $config"
  backup_file "$config"
  set_or_append_toml "$config" "USE_EXTERNAL_SOCKS5" "false"
  ok "MasterDnsVPN external SOCKS5 disabled. FORWARD_IP/FORWARD_PORT were left in place for easy reactivation."
}

enable_masterdns_warp() {
  set_warp_proxy_mode
  patch_masterdns_config
  restart_masterdns
  ok "MasterDnsVPN WARP routing is active through Cloudflare WARP proxy at 127.0.0.1:$WARP_PROXY_PORT."
}

disable_masterdns_warp() {
  unpatch_masterdns_config
  restart_masterdns
}

remove_warp_bridge() {
  check_sqlite_mode
  local tmp next
  tmp="$(mktemp)"
  next="$(mktemp)"
  get_xray_config_file "$tmp"
  jq --arg tag "masterdns-warp-socks" '
    .inbounds = ((.inbounds // []) | map(select(.tag != $tag))) |
    .routing.rules = ((.routing.rules // []) | map(select((.inboundTag // []) != [$tag])))
  ' "$tmp" > "$next"
  save_xray_config_file "$next"
  rm -f "$tmp" "$next"
  restart_xui
  ok "Local MasterDnsVPN WARP bridge removed from Xray config."
}

enable_warp_both() {
  enable_xui_warp_all
  enable_masterdns_warp
}

disable_warp_both() {
  if [[ -f "$MASTERDNS_DIR/server_config.toml" ]]; then
    unpatch_masterdns_config || true
    restart_masterdns
  fi
  remove_generated_warp_from_xray
  restart_xui
}

repair_xray_after_warp() {
  warn "This removes only the WARP config generated by this manager and disables MasterDnsVPN external SOCKS."
  remove_generated_warp_from_xray
  if [[ -f "$MASTERDNS_DIR/server_config.toml" ]]; then
    unpatch_masterdns_config || true
    restart_masterdns
  fi
  restart_xui
  ok "Repair finished. Check x-ui status again."
}

warp_status() {
  echo ""
  echo "WARP status"
  echo "-----------"
  if [[ -f "$XUI_DB" ]]; then
    local cfg
    cfg="$(mktemp)"
    if get_xray_config_file "$cfg" >/dev/null 2>&1; then
      jq -r --arg tag "$WARP_OUTBOUND_TAG" '
        "3x-ui WARP SOCKS outbound: " + (if any(.outbounds[]?; .tag == $tag and .protocol == "socks") then "present" else "missing" end),
        "3x-ui catch-all WARP route: " + (if any(.routing.rules[]?; . == {"type":"field","outboundTag":$tag}) then "enabled" else "disabled" end)
      ' "$cfg"
    fi
    rm -f "${cfg:-}"
  else
    echo "3x-ui DB: missing"
  fi

  if command -v warp-cli >/dev/null 2>&1; then
    echo "Cloudflare WARP client: installed"
    warp-cli status 2>/dev/null || true
  else
    echo "Cloudflare WARP client: missing"
  fi

  if [[ -f "$MASTERDNS_DIR/server_config.toml" ]]; then
    if grep -qE '^USE_EXTERNAL_SOCKS5[[:space:]]*=[[:space:]]*true' "$MASTERDNS_DIR/server_config.toml"; then
      echo "MasterDnsVPN WARP via SOCKS: enabled"
    else
      echo "MasterDnsVPN WARP via SOCKS: disabled"
    fi
  else
    echo "MasterDnsVPN config: missing"
  fi
  echo ""
}

test_public_ip() {
  require_cmd curl
  echo ""
  echo "Direct server IP:"
  curl -fsSL --max-time 10 https://www.cloudflare.com/cdn-cgi/trace | grep -E '^(ip|warp)=' || true
  echo ""
  echo "Via Cloudflare WARP local SOCKS proxy:"
  if curl --socks5-hostname "127.0.0.1:$WARP_PROXY_PORT" -fsSL --max-time 15 https://www.cloudflare.com/cdn-cgi/trace | grep -E '^(ip|warp)='; then
    ok "WARP proxy test finished."
  else
    warn "WARP proxy test failed. Make sure WARP is active."
  fi
}

open_xui_menu() {
  if command -v x-ui >/dev/null 2>&1; then
    x-ui
  else
    die "x-ui command not found. Install 3x-ui first."
  fi
}

service_status() {
  echo ""
  systemctl status x-ui --no-pager -l 2>/dev/null || true
  echo ""
  systemctl status masterdnsvpn --no-pager -l 2>/dev/null || true
}

show_info() {
  echo ""
  echo "3x-ui admin menu:"
  echo "  sudo x-ui"
  echo ""
  echo "Combined manager:"
  echo "  sudo masterdns-3xui"
  echo ""
  echo "MasterDnsVPN files:"
  echo "  $MASTERDNS_DIR/server_config.toml"
  echo "  $MASTERDNS_DIR/encrypt_key.txt"
  echo ""
  echo "Logs:"
  echo "  sudo journalctl -u x-ui -f"
  echo "  sudo journalctl -u masterdnsvpn -f"
  echo ""
}

install_or_update_all() {
  if [[ -f ./install.sh ]]; then
    bash ./install.sh
  else
    local tmp
    tmp="$(mktemp)"
    curl -fsSL https://raw.githubusercontent.com/DarkPoesidon/Masterdns-3xui/main/install.sh -o "$tmp"
    bash "$tmp"
    rm -f "$tmp"
  fi
}

warp_menu() {
  while true; do
    clear || true
    cat <<EOF
WARP Management
---------------
1) Turn WARP ON for both MasterDNS and 3x-ui
2) Turn WARP OFF for both
3) Activate WARP for 3x-ui only
4) Deactivate WARP for 3x-ui only
5) Activate WARP for MasterDnsVPN only
6) Deactivate WARP for MasterDnsVPN only
7) Show WARP status
8) Test public IP / WARP path
9) Remove old MasterDnsVPN Xray bridge
10) Repair Xray after failed WARP start
0) Back
EOF
    read -r -p "Choose: " choice
    case "$choice" in
      1) confirm "Route both services through WARP where supported?" "Y" && enable_warp_both; pause ;;
      2) confirm "Turn WARP routing off for both services?" "Y" && disable_warp_both; pause ;;
      3) confirm "Route 3x-ui/Xray default outbound traffic through WARP?" "Y" && enable_xui_warp_all; pause ;;
      4) confirm "Disable 3x-ui/Xray catch-all WARP route?" "Y" && disable_xui_warp_all; pause ;;
      5) confirm "Route MasterDnsVPN egress through Cloudflare WARP local SOCKS?" "Y" && enable_masterdns_warp; pause ;;
      6) confirm "Disable MasterDnsVPN external SOCKS5 WARP route?" "Y" && disable_masterdns_warp; pause ;;
      7) warp_status; pause ;;
      8) test_public_ip; pause ;;
      9) confirm "Remove only the old local Xray SOCKS bridge?" "Y" && remove_warp_bridge; pause ;;
      10) confirm "Remove generated WARP config and restart x-ui/Xray?" "Y" && repair_xray_after_warp; pause ;;
      0) return ;;
      *) warn "Invalid choice"; pause ;;
    esac
  done
}

main_menu() {
  while true; do
    clear || true
    cat <<EOF
MasterDNS + 3x-ui Manager
-------------------------
1) Install / update MasterDNS + original 3x-ui
2) Open original 3x-ui admin menu
3) WARP Management
4) Show service status
5) Show important info
6) Restart both services
0) Exit
EOF
    read -r -p "Choose: " choice
    case "$choice" in
      1) install_or_update_all; pause ;;
      2) open_xui_menu; pause ;;
      3) warp_menu ;;
      4) service_status; pause ;;
      5) show_info; pause ;;
      6) restart_xui; restart_masterdns; pause ;;
      0) exit 0 ;;
      *) warn "Invalid choice"; pause ;;
    esac
  done
}

main() {
  need_root
  ensure_dirs
  case "${1:-}" in
    install-tools) install_tools ;;
    warp-on) enable_warp_both ;;
    warp-off) disable_warp_both ;;
    repair-xray) repair_xray_after_warp ;;
    warp-status) warp_status ;;
    test-ip) test_public_ip ;;
    x-ui) open_xui_menu ;;
    *) main_menu ;;
  esac
}

main "$@"
