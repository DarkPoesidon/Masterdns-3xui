#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'

APP_DIR="/opt/masterdns-3xui"
BACKUP_DIR="$APP_DIR/backups"
MASTERDNS_DIR="/opt/masterdnsvpn"
MASTERDNS_SERVICE="masterdnsvpn"
MASTERDNS_CONFIG="$MASTERDNS_DIR/server_config.toml"
MASTERDNS_KEY="$MASTERDNS_DIR/encrypt_key.txt"
XUI_DB="/etc/x-ui/x-ui.db"
WARP_PROXY_HOST="127.0.0.1"
WARP_PROXY_PORT="40000"
LEGACY_XUI_WARP_TAG="warp"
LEGACY_XUI_BRIDGE_TAG="masterdns-warp-socks"

red=$'\033[0;31m'
green=$'\033[0;32m'
yellow=$'\033[0;33m'
blue=$'\033[0;34m'
plain=$'\033[0m'

info() { echo -e "${blue}[INFO]${plain} $*"; }
ok() { echo -e "${green}[OK]${plain} $*"; }
warn() { echo -e "${yellow}[WARN]${plain} $*"; }
err() { echo -e "${red}[ERROR]${plain} $*" >&2; }
die() { err "$*"; exit 1; }

need_root() { [[ "${EUID}" -eq 0 ]] || die "Run as root: sudo masterdns-3xui"; }
pause() { read -r -p "Press Enter to continue... " _ || true; }

confirm() {
  local prompt="${1:-Continue?}" default="${2:-Y}" ans
  read -r -p "${prompt} [${default}/n]: " ans
  ans="${ans:-$default}"
  [[ "$ans" == "y" || "$ans" == "Y" || "$ans" == "yes" || "$ans" == "YES" ]]
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "Missing command: $1. Install dependencies from the main installer first."
}

ensure_dirs() {
  mkdir -p "$APP_DIR" "$BACKUP_DIR"
}

timestamp() { date +%Y%m%d-%H%M%S; }

backup_file() {
  local file="$1"
  [[ -f "$file" ]] || return 0
  mkdir -p "$BACKUP_DIR"
  cp -a "$file" "$BACKUP_DIR/$(basename "$file").$(timestamp).bak"
}

detect_pm() {
  if command -v apt-get >/dev/null 2>&1; then echo apt
  elif command -v dnf >/dev/null 2>&1; then echo dnf
  elif command -v yum >/dev/null 2>&1; then echo yum
  elif command -v pacman >/dev/null 2>&1; then echo pacman
  elif command -v zypper >/dev/null 2>&1; then echo zypper
  elif command -v apk >/dev/null 2>&1; then echo apk
  else die "No supported package manager found."
  fi
}

install_tools() {
  local pm
  pm="$(detect_pm)"
  case "$pm" in
    apt)
      apt-get update
      apt-get install -y curl wget ca-certificates jq sqlite3 iproute2 lsof unzip tar openssl gpg lsb-release
      ;;
    dnf) dnf -y install curl wget ca-certificates jq sqlite iproute lsof unzip tar openssl gpg lsb-release ;;
    yum) yum -y install curl wget ca-certificates jq sqlite iproute lsof unzip tar openssl gpg redhat-lsb-core ;;
    pacman) pacman -Sy --noconfirm curl wget ca-certificates jq sqlite iproute2 lsof unzip tar openssl gnupg ;;
    zypper)
      zypper refresh
      zypper -q install -y curl wget ca-certificates jq sqlite3-tools iproute2 lsof unzip tar openssl gpg2 lsb-release
      ;;
    apk)
      apk update
      apk add curl wget ca-certificates jq sqlite iproute2 lsof unzip tar openssl gnupg
      ;;
  esac
}

has_systemd_service() {
  systemctl list-unit-files 2>/dev/null | grep -q "^$1\\.service"
}

masterdns_installed() {
  [[ -f "$MASTERDNS_CONFIG" ]] && has_systemd_service "$MASTERDNS_SERVICE"
}

ensure_masterdns_config() {
  [[ -f "$MASTERDNS_CONFIG" ]] || die "MasterDnsVPN config not found: $MASTERDNS_CONFIG"
}

systemctl_master() {
  has_systemd_service "$MASTERDNS_SERVICE" || die "MasterDnsVPN service is not installed."
  systemctl "$@" "$MASTERDNS_SERVICE"
}

restart_masterdns() {
  systemctl_master restart
}

set_or_append_toml() {
  local file="$1" key="$2" value="$3"
  if grep -qE "^${key}[[:space:]]*=" "$file"; then
    sed -i -E "s|^${key}[[:space:]]*=.*$|${key} = ${value}|" "$file"
  else
    printf '\n%s = %s\n' "$key" "$value" >> "$file"
  fi
}

get_toml_value() {
  local key="$1"
  [[ -f "$MASTERDNS_CONFIG" ]] || return 0
  grep -E "^${key}[[:space:]]*=" "$MASTERDNS_CONFIG" | tail -n 1 | sed -E "s/^${key}[[:space:]]*=[[:space:]]*//"
}

show_masterdns_status() {
  echo ""
  echo "MasterDnsVPN status"
  echo "-------------------"
  if has_systemd_service "$MASTERDNS_SERVICE"; then
    systemctl is-active "$MASTERDNS_SERVICE" >/dev/null 2>&1 && echo "Service: running" || echo "Service: not running"
    systemctl is-enabled "$MASTERDNS_SERVICE" >/dev/null 2>&1 && echo "Autostart: enabled" || echo "Autostart: disabled"
  else
    echo "Service: not installed"
  fi
  echo "Config: $MASTERDNS_CONFIG"
  [[ -f "$MASTERDNS_CONFIG" ]] && echo "DOMAIN: $(get_toml_value DOMAIN)"
  [[ -f "$MASTERDNS_CONFIG" ]] && echo "External SOCKS5: $(get_toml_value USE_EXTERNAL_SOCKS5) -> $(get_toml_value FORWARD_IP):$(get_toml_value FORWARD_PORT)"
  [[ -f "$MASTERDNS_KEY" ]] && echo "Encryption key: $(tr -d '\r\n' < "$MASTERDNS_KEY")"
  echo ""
}

show_masterdns_info() {
  show_masterdns_status
  echo "Useful files"
  echo "------------"
  echo "$MASTERDNS_CONFIG"
  echo "$MASTERDNS_KEY"
  echo "$BACKUP_DIR"
  echo ""
  echo "Useful commands"
  echo "---------------"
  echo "sudo systemctl restart $MASTERDNS_SERVICE"
  echo "sudo journalctl -u $MASTERDNS_SERVICE -f"
  echo "sudo x-ui"
  echo ""
}

edit_masterdns_config() {
  ensure_masterdns_config
  backup_file "$MASTERDNS_CONFIG"
  "${EDITOR:-nano}" "$MASTERDNS_CONFIG" || "${VISUAL:-vi}" "$MASTERDNS_CONFIG"
  confirm "Restart MasterDnsVPN now?" "Y" && restart_masterdns
}

change_masterdns_domain() {
  ensure_masterdns_config
  local domain
  read -r -p "Enter delegated MasterDnsVPN domain (example: v.example.com): " domain
  [[ -n "$domain" ]] || die "Domain cannot be empty."
  backup_file "$MASTERDNS_CONFIG"
  set_or_append_toml "$MASTERDNS_CONFIG" "DOMAIN" "[\"$domain\"]"
  ok "DOMAIN updated to $domain"
  confirm "Restart MasterDnsVPN now?" "Y" && restart_masterdns
}

backup_masterdns_config() {
  ensure_masterdns_config
  backup_file "$MASTERDNS_CONFIG"
  [[ -f "$MASTERDNS_KEY" ]] && backup_file "$MASTERDNS_KEY"
  ok "Backup saved in $BACKUP_DIR"
}

restore_latest_masterdns_config() {
  local latest
  latest="$(ls -1t "$BACKUP_DIR"/server_config.toml.*.bak 2>/dev/null | head -n 1 || true)"
  [[ -n "$latest" ]] || die "No config backup found in $BACKUP_DIR"
  cp -a "$MASTERDNS_CONFIG" "$BACKUP_DIR/server_config.toml.before-restore.$(timestamp).bak" 2>/dev/null || true
  cp -a "$latest" "$MASTERDNS_CONFIG"
  ok "Restored $latest"
  confirm "Restart MasterDnsVPN now?" "Y" && restart_masterdns
}

check_dns_port() {
  echo ""
  echo "Port 53 check"
  echo "-------------"
  if command -v ss >/dev/null 2>&1; then
    ss -lntup 2>/dev/null | grep -E ':(53)\b' || echo "No listeners found on TCP/UDP 53."
  elif command -v lsof >/dev/null 2>&1; then
    lsof -iTCP:53 -iUDP:53 -P -n || echo "No listeners found on TCP/UDP 53."
  else
    warn "Neither ss nor lsof is available."
  fi
  echo ""
}

tail_masterdns_logs() {
  has_systemd_service "$MASTERDNS_SERVICE" || die "MasterDnsVPN service is not installed."
  journalctl -u "$MASTERDNS_SERVICE" -n 120 --no-pager
  echo ""
  confirm "Follow live logs now?" "Y" && journalctl -u "$MASTERDNS_SERVICE" -f
}

open_xui_menu() {
  if command -v x-ui >/dev/null 2>&1; then
    x-ui
  else
    die "x-ui command not found. Install 3x-ui first."
  fi
}

install_or_update_all() {
  if [[ -f ./install.sh ]]; then
    bash ./install.sh
  else
    local tmp
    tmp="$(mktemp)"
    curl -fsSL https://raw.githubusercontent.com/DarkPoesidon/Masterdns-3xui/main/install.sh -o "$tmp"
    bash "$tmp"
    rm -f "$tmp"
  fi
}

warp_cli() {
  warp-cli --accept-tos "$@" 2>/dev/null || warp-cli "$@"
}

install_cloudflare_warp() {
  if command -v warp-cli >/dev/null 2>&1; then
    ok "Cloudflare WARP is already installed."
    return 0
  fi

  local pm codename
  pm="$(detect_pm)"
  case "$pm" in
    apt)
      apt-get update
      apt-get install -y curl ca-certificates gpg lsb-release
      codename="$(lsb_release -cs 2>/dev/null || true)"
      if [[ -z "$codename" ]]; then
        . /etc/os-release
        codename="${VERSION_CODENAME:-}"
      fi
      [[ -n "$codename" ]] || die "Could not detect Debian/Ubuntu codename for Cloudflare WARP repository."
      mkdir -p /usr/share/keyrings
      curl -fsSL https://pkg.cloudflareclient.com/pubkey.gpg | gpg --yes --dearmor --output /usr/share/keyrings/cloudflare-warp-archive-keyring.gpg
      echo "deb [signed-by=/usr/share/keyrings/cloudflare-warp-archive-keyring.gpg] https://pkg.cloudflareclient.com/ $codename main" > /etc/apt/sources.list.d/cloudflare-client.list
      apt-get update
      apt-get install -y cloudflare-warp
      ;;
    dnf|yum)
      rpm --import https://pkg.cloudflareclient.com/pubkey.gpg || true
      curl -fsSL https://pkg.cloudflareclient.com/cloudflare-warp-ascii.repo -o /etc/yum.repos.d/cloudflare-warp.repo
      "$pm" -y install cloudflare-warp
      ;;
    *)
      die "Automatic Cloudflare WARP install supports apt, dnf, and yum. You can still use menu option 8 with any existing SOCKS5 proxy."
      ;;
  esac
}

start_warp_service() {
  command -v warp-cli >/dev/null 2>&1 || die "warp-cli is not installed."
  if command -v systemctl >/dev/null 2>&1; then
    systemctl enable --now warp-svc >/dev/null 2>&1 || true
  fi
  if command -v service >/dev/null 2>&1; then
    service warp-svc start >/dev/null 2>&1 || true
  fi
}

stop_warp_service() {
  if command -v systemctl >/dev/null 2>&1; then
    systemctl stop warp-svc >/dev/null 2>&1 || true
  elif command -v service >/dev/null 2>&1; then
    service warp-svc stop >/dev/null 2>&1 || true
  fi
}

restart_warp_service() {
  if command -v systemctl >/dev/null 2>&1; then
    systemctl restart warp-svc >/dev/null 2>&1 || true
  elif command -v service >/dev/null 2>&1; then
    service warp-svc restart >/dev/null 2>&1 || true
  fi
}

ensure_warp_proxy() {
  install_cloudflare_warp
  start_warp_service
  if ! warp_cli registration show >/dev/null 2>&1; then
    warp_cli registration new || warp_cli register || true
  fi
  warp_cli tunnel protocol set MASQUE >/dev/null 2>&1 || true
  warp_cli set-proxy-port "$WARP_PROXY_PORT" >/dev/null 2>&1 || warp_cli proxy port "$WARP_PROXY_PORT" >/dev/null 2>&1 || true
  warp_cli mode proxy >/dev/null 2>&1 || warp_cli set-mode proxy >/dev/null 2>&1 || die "Could not set WARP proxy mode."
  warp_cli connect >/dev/null 2>&1 || true
  ok "Cloudflare WARP proxy requested on $WARP_PROXY_HOST:$WARP_PROXY_PORT"
}

enable_masterdns_socks() {
  local host="$1" port="$2" auth="${3:-false}" user="${4:-}" pass="${5:-}"
  ensure_masterdns_config
  backup_file "$MASTERDNS_CONFIG"
  set_or_append_toml "$MASTERDNS_CONFIG" "USE_EXTERNAL_SOCKS5" "true"
  set_or_append_toml "$MASTERDNS_CONFIG" "FORWARD_IP" "\"$host\""
  set_or_append_toml "$MASTERDNS_CONFIG" "FORWARD_PORT" "$port"
  set_or_append_toml "$MASTERDNS_CONFIG" "SOCKS5_AUTH" "$auth"
  if [[ "$auth" == "true" ]]; then
    set_or_append_toml "$MASTERDNS_CONFIG" "SOCKS5_USER" "\"$user\""
    set_or_append_toml "$MASTERDNS_CONFIG" "SOCKS5_PASS" "\"$pass\""
  fi
  restart_masterdns
  ok "MasterDnsVPN now uses SOCKS5 upstream $host:$port"
}

enable_masterdns_warp() {
  ensure_warp_proxy
  enable_masterdns_socks "$WARP_PROXY_HOST" "$WARP_PROXY_PORT" "false"
}

disable_masterdns_socks() {
  ensure_masterdns_config
  backup_file "$MASTERDNS_CONFIG"
  set_or_append_toml "$MASTERDNS_CONFIG" "USE_EXTERNAL_SOCKS5" "false"
  restart_masterdns
  ok "MasterDnsVPN external SOCKS5 routing is disabled."
}

configure_custom_socks() {
  local host port auth user="" pass=""
  read -r -p "SOCKS5 host/IP: " host
  read -r -p "SOCKS5 port: " port
  [[ -n "$host" && "$port" =~ ^[0-9]+$ ]] || die "Invalid SOCKS5 host or port."
  if confirm "Does this SOCKS5 proxy require username/password?" "n"; then
    auth="true"
    read -r -p "SOCKS5 username: " user
    read -r -s -p "SOCKS5 password: " pass
    echo ""
  else
    auth="false"
  fi
  enable_masterdns_socks "$host" "$port" "$auth" "$user" "$pass"
}

warp_status() {
  echo ""
  echo "MasterDnsVPN WARP / SOCKS status"
  echo "-------------------------------"
  if command -v warp-cli >/dev/null 2>&1; then
    echo "Cloudflare WARP client: installed"
    warp-cli status 2>/dev/null || true
  else
    echo "Cloudflare WARP client: not installed"
  fi
  if command -v ss >/dev/null 2>&1; then
    ss -ltn 2>/dev/null | grep -q ":$WARP_PROXY_PORT " && echo "Local WARP SOCKS port: listening on $WARP_PROXY_PORT" || echo "Local WARP SOCKS port: not confirmed"
  fi
  if [[ -f "$MASTERDNS_CONFIG" ]]; then
    echo "MasterDnsVPN external SOCKS5: $(get_toml_value USE_EXTERNAL_SOCKS5)"
    echo "MasterDnsVPN upstream: $(get_toml_value FORWARD_IP):$(get_toml_value FORWARD_PORT)"
  else
    echo "MasterDnsVPN config: missing"
  fi
  echo ""
}

test_public_ip() {
  require_cmd curl
  echo ""
  echo "Direct server path:"
  curl -fsSL --max-time 10 https://www.cloudflare.com/cdn-cgi/trace | grep -E '^(ip|warp)=' || true
  echo ""
  echo "Cloudflare WARP SOCKS path:"
  if curl --socks5-hostname "$WARP_PROXY_HOST:$WARP_PROXY_PORT" -fsSL --max-time 15 https://www.cloudflare.com/cdn-cgi/trace | grep -E '^(ip|warp)='; then
    ok "WARP SOCKS test finished."
  else
    warn "WARP SOCKS test failed. Use WARP status and logs to diagnose."
  fi
  echo ""
}

uninstall_cloudflare_warp() {
  confirm "Remove cloudflare-warp package from this server?" "n" || return 0
  stop_warp_service
  local pm
  pm="$(detect_pm)"
  case "$pm" in
    apt) apt-get remove -y cloudflare-warp ;;
    dnf|yum) "$pm" -y remove cloudflare-warp ;;
    pacman) pacman -Rns --noconfirm cloudflare-warp ;;
    zypper) zypper -q remove -y cloudflare-warp ;;
    apk) apk del cloudflare-warp ;;
  esac
}

clean_legacy_xui_warp() {
  [[ -f "$XUI_DB" ]] || { warn "3x-ui DB not found; nothing to clean."; return 0; }
  require_cmd sqlite3
  require_cmd jq
  local raw tmp next escaped
  raw="$(sqlite3 "$XUI_DB" "SELECT value FROM settings WHERE key = 'xrayTemplateConfig' ORDER BY id DESC LIMIT 1;" || true)"
  [[ -n "$raw" ]] || { warn "No xrayTemplateConfig found; nothing to clean."; return 0; }
  tmp="$(mktemp)"
  next="$(mktemp)"
  printf '%s' "$raw" > "$tmp"
  jq --arg warp "$LEGACY_XUI_WARP_TAG" --arg bridge "$LEGACY_XUI_BRIDGE_TAG" '
    .outbounds = ((.outbounds // []) | map(select(.tag != $warp))) |
    .inbounds = ((.inbounds // []) | map(select(.tag != $bridge))) |
    .routing.rules = ((.routing.rules // []) | map(select(.outboundTag != $warp and ((.inboundTag // []) != [$bridge]))))
  ' "$tmp" > "$next"
  backup_file "$XUI_DB"
  escaped="$(jq -c . "$next" | sed "s/'/''/g")"
  sqlite3 "$XUI_DB" "UPDATE settings SET value = '$escaped' WHERE key = 'xrayTemplateConfig';"
  rm -f "$tmp" "$next"
  if command -v systemctl >/dev/null 2>&1 && has_systemd_service x-ui; then
    systemctl restart x-ui || true
  fi
  ok "Removed legacy manager-created WARP entries from 3x-ui/Xray config."
}

service_menu() {
  while true; do
    clear || true
    cat <<EOF
MasterDnsVPN Service
--------------------
1) Status
2) Start
3) Stop
4) Restart
5) Enable autostart
6) Disable autostart
7) Logs
0) Back
EOF
    read -r -p "Choose: " choice
    case "$choice" in
      1) show_masterdns_status; pause ;;
      2) systemctl_master start; pause ;;
      3) systemctl_master stop; pause ;;
      4) restart_masterdns; pause ;;
      5) systemctl_master enable; pause ;;
      6) systemctl_master disable; pause ;;
      7) tail_masterdns_logs; pause ;;
      0) return ;;
      *) warn "Invalid choice"; pause ;;
    esac
  done
}

config_menu() {
  while true; do
    clear || true
    cat <<EOF
MasterDnsVPN Config
-------------------
1) Show config, domain, key
2) Edit config file
3) Change DOMAIN
4) Backup config and key
5) Restore latest config backup
6) Check port 53 conflicts
0) Back
EOF
    read -r -p "Choose: " choice
    case "$choice" in
      1) show_masterdns_info; pause ;;
      2) edit_masterdns_config; pause ;;
      3) change_masterdns_domain; pause ;;
      4) backup_masterdns_config; pause ;;
      5) restore_latest_masterdns_config; pause ;;
      6) check_dns_port; pause ;;
      0) return ;;
      *) warn "Invalid choice"; pause ;;
    esac
  done
}

warp_menu() {
  while true; do
    clear || true
    cat <<EOF
MasterDnsVPN WARP / SOCKS
-------------------------
1) Enable MasterDnsVPN through Cloudflare WARP
2) Disable MasterDnsVPN WARP/SOCKS
3) Install/start Cloudflare WARP proxy only
4) Restart Cloudflare WARP service
5) Stop Cloudflare WARP service
6) Show WARP/SOCKS status
7) Test direct IP vs WARP IP
8) Use custom SOCKS5 upstream for MasterDnsVPN
9) Remove Cloudflare WARP package
0) Back
EOF
    read -r -p "Choose: " choice
    case "$choice" in
      1) confirm "Enable WARP only for MasterDnsVPN?" "Y" && enable_masterdns_warp; pause ;;
      2) confirm "Disable MasterDnsVPN external SOCKS/WARP?" "Y" && disable_masterdns_socks; pause ;;
      3) ensure_warp_proxy; pause ;;
      4) restart_warp_service; pause ;;
      5) stop_warp_service; pause ;;
      6) warp_status; pause ;;
      7) test_public_ip; pause ;;
      8) configure_custom_socks; pause ;;
      9) uninstall_cloudflare_warp; pause ;;
      0) return ;;
      *) warn "Invalid choice"; pause ;;
    esac
  done
}

main_menu() {
  while true; do
    clear || true
    cat <<EOF
MasterDnsVPN Manager
--------------------
1) Install / update MasterDnsVPN + original 3x-ui
2) MasterDnsVPN service
3) MasterDnsVPN config, domain, key, backups
4) WARP / SOCKS for MasterDnsVPN only
5) Open original 3x-ui admin menu
6) Clean old 3x-ui WARP changes made by this manager
7) Show full status
0) Exit
EOF
    read -r -p "Choose: " choice
    case "$choice" in
      1) install_or_update_all; pause ;;
      2) service_menu ;;
      3) config_menu ;;
      4) warp_menu ;;
      5) open_xui_menu; pause ;;
      6) confirm "Clean old generated WARP entries from 3x-ui/Xray config?" "Y" && clean_legacy_xui_warp; pause ;;
      7) show_masterdns_info; warp_status; pause ;;
      0) exit 0 ;;
      *) warn "Invalid choice"; pause ;;
    esac
  done
}

main() {
  need_root
  ensure_dirs
  case "${1:-}" in
    install-tools) install_tools ;;
    master-status|status) show_masterdns_status ;;
    master-start) systemctl_master start ;;
    master-stop) systemctl_master stop ;;
    master-restart) restart_masterdns ;;
    master-logs) tail_masterdns_logs ;;
    master-warp-on|warp-on) enable_masterdns_warp ;;
    master-warp-off|warp-off) disable_masterdns_socks ;;
    warp-status) warp_status ;;
    test-ip) test_public_ip ;;
    repair-xray|clean-xui-warp) clean_legacy_xui_warp ;;
    x-ui) open_xui_menu ;;
    *) main_menu ;;
  esac
}

main "$@"
